---
import BaseLayout from "../layouts/BaseLayout.astro";
import { apiGet } from "../lib/api";

const cookieHeader = Astro.request.headers.get("cookie") ?? "";

// ── SSR fetch paralel ─────────────────────────────────────────────────────────
const [provinces, categories] = await Promise.all([
  apiGet<{ id: string; name: string }[]>("/api/wai/provinces", cookieHeader),
  apiGet<{ id: number; name: string }[]>("/api/categories", cookieHeader),
]);

// ── Decode user dari cookie untuk ambil ID ────────────────────────────────
function getUserFromCookie(cookie: string) {
  const match = cookie
    .split(";")
    .map((c) => c.trim())
    .find((c) => c.startsWith("auth_token="));
  if (!match) return null;
  try {
    const token = decodeURIComponent(match.slice("auth_token=".length));
    const payload = token.split(".")[1];
    return JSON.parse(atob(payload.replace(/-/g, "+").replace(/_/g, "/")));
  } catch {
    return null;
  }
}

const currentUser = getUserFromCookie(cookieHeader);

const latestJobs = await apiGet<Array<{
  id: number;
  slug: string;
  job_title: string;
  job_type: number;
  job_type_label: string;
  sallary_formatted: string;
  description: string;
  location: string;
  company: { name: string; logo: string | null };
  category: string;
}>>("/api/vacancies/latest?limit=6", cookieHeader) ?? [];

// console.log("latestJobs:", JSON.stringify(latestJobs, null, 2));
const JOB_TYPE_CLASS: Record<number, string> = {
  0: "badge-primary",
  1: "badge-dark",
  2: "badge-info",
  3: "badge-default",
};

// Fetch liked vacancy IDs jika user sudah login
const likedIds: number[] = currentUser?.id
  ? (await apiGet<number[]>(
      `/api/vacancies/liked?applicant_id=${currentUser.id}`,
      cookieHeader,
    )) ?? []
  : [];

const API_URL = import.meta.env.PUBLIC_API_URL;
