  <script>

    // Init form search di halaman jobs (reuse logic yang sama)
    const initJobsSearch = () => {
      const form = document.querySelector<HTMLFormElement>("[data-search-home]");
      const submitBtn = document.querySelector("[data-search-home-submit]");
      if (!form) return;

      // Tombol search desktop trigger submit form
      submitBtn?.addEventListener("click", () => form.requestSubmit());

      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const params = new URLSearchParams();
        const keyword  = (form.querySelector<HTMLInputElement>("#input-keyword"))?.value.trim() ?? "";
        const province = (form.querySelector<HTMLSelectElement>("#select-province"))?.value ?? "";
        const category = (form.querySelector<HTMLSelectElement>("#select-category"))?.value ?? "";

        if (keyword)  params.set("q", keyword);
        if (province) params.set("province", province);
        if (category) params.set("category", category);
        params.set("page", "1"); // reset ke halaman 1 saat search baru

        const query = params.toString();
        window.location.href = `/jobs${query ? `?${query}` : ""}`;
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initJobsSearch);
    } else {
      initJobsSearch();
    }
    window.addEventListener("barba:after", initJobsSearch);
  </script>
