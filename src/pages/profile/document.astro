  <!-- ── Modal Preview Dokumen ─────────────────────────────────────────────── -->
  <div id="modal-doc-preview" class="fixed inset-0 z-[1000] invisible" data-modal>
    <div class="relative w-full h-dvh flex flex-col" data-lenis-prevent>
      <!-- Backdrop -->
      <div class="absolute inset-0 bg-dark-950/70" data-modal-hide></div>
      <!-- Panel -->
      <div class="relative flex flex-col w-full h-full max-w-4xl mx-auto my-auto px-4 py-4 pointer-events-none | lg:py-8">
        <div class="relative flex flex-col h-full bg-white rounded-lg overflow-hidden pointer-events-auto shadow-2xl">
          <!-- Header modal -->
          <div class="flex items-center justify-between px-6 py-4 border-b border-dark-100 shrink-0">
            <h6 class="font-semibold text-sm" id="modal-doc-preview-title">Preview Dokumen</h6>
            <button
              type="button"
              class="btn btn-icon btn-xs btn-dark"
              data-modal-hide
              title="Tutup"
            >
              <svg class="icon icon-stroke" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19.0005 4.99988L5.00049 18.9999M5.00049 4.99988L19.0005 18.9999" stroke="#141B34" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <!-- iframe PDF -->
          <div class="relative flex-1 min-h-0">
            <iframe
              id="modal-doc-preview-iframe"
              src=""
              class="w-full h-full border-0"
              title="Preview dokumen"
            ></iframe>
            <!-- Fallback jika iframe tidak support -->
