                            </svg>
                          </div>
                        </button>
                      </div>

                      <div
                        class="absolute inset-y-0 left-0 w-dvw bg-dark-50 rounded-l-lg -z-1 | not-lg:hidden"
                      ></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
