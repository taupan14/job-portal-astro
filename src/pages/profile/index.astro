---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { apiGet } from "../../lib/api";

const cookieHeader = Astro.request.headers.get("cookie") ?? "";

// ── Decode user dari cookie untuk ambil ID ────────────────────────────────
function getUserFromCookie(cookie: string) {
  const match = cookie
    .split(";")
    .map((c) => c.trim())
    .find((c) => c.startsWith("auth_token="));
  if (!match) return null;
  try {
    const token = decodeURIComponent(match.slice("auth_token=".length));
    const payload = token.split(".")[1];
    return JSON.parse(atob(payload.replace(/-/g, "+").replace(/_/g, "/")));
  } catch {
    return null;
  }
}

const currentUser = getUserFromCookie(cookieHeader);
if (!currentUser?.id) return Astro.redirect("/login?redirect=/profile");

// ── Fetch semua data paralel via SSR ─────────────────────────────────────
const [profileData, educations, provinces] = await Promise.all([
  apiGet<any>(`/api/applicants/${currentUser.id}`, cookieHeader),
  apiGet<{ id: number; name: string }[]>("/api/educations", cookieHeader),
  apiGet<{ id: string; name: string }[]>("/api/wai/provinces", cookieHeader),
]);

// ── Resolve province ID berdasarkan nama ──────────────────────────────────
const provMatch = profileData?.province
  ? (provinces ?? []).find(
      (p) =>
        p.name === profileData.province ||
        String(p.id) === String(profileData.province),
    )
  : null;

// ── Helper data ───────────────────────────────────────────────────────────
const formalEdu = profileData?.education?.[0] ?? null;
const nonformalEdu = profileData?.nonformal?.[0] ?? null;
const experiences = profileData?.experience ?? [];

const avatarUrl = profileData?.avatar
  ? `${import.meta.env.PUBLIC_API_URL}/pubs/uploads/avatar/${profileData.avatar}`
  : null;

const formattedDob = "";
// const formattedDob = profileData?.date_of_birth
//   ? new Date(profileData.date_of_birth).toLocaleDateString("id-ID", {
//       day: "2-digit",
//       month: "long",
//       year: "numeric",
//     })
//   : "";

// console.log("profileData.province:", profileData?.province);
// console.log("provinces sample:", provinces?.slice(0, 3));
// console.log("provMatch:", provMatch);
