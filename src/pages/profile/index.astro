                                      <input
                                        type="text"
                                        class="c-input"
                                        name="formal_start_date"
                                        id="formal-from-date"
                                        placeholder="dd mmmm, yyyy"
                                        readonly
                                        value={formalEdu?.start_date ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="formal-to-date"
                                        class="c-label">Tanggal Selesai</label
                                      >
                                      <input
                                        type="text"
                                        class="c-input"
                                        name="formal_finish_date"
                                        id="formal-to-date"
                                        placeholder="dd mmmm, yyyy"
                                        readonly
                                        value={formalEdu?.finish_date ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div id="formal-datepicker" class="hidden">
                                  <div data-rangepicker></div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-jurusan" class="c-label"
                                        >Jurusan / Program Studi</label
                                      >
                                      <input
                                        type="text"
                                        name="study_name"
                                        id="input-jurusan"
                                        class="c-input"
                                        placeholder="Masukan jurusan *"
                                        value={formalEdu?.study_name ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>

                            <!-- Pendidikan Non-Formal -->
                            <div class="grid gap-8">
                              <div class="flex items-center gap-4">
                                <h5>Informasi Non-Formal</h5>
                                <span
                                  class="text-xs font-medium text-dark-400 bg-dark-100 px-2 py-1 rounded-full"
                                  >Opsional</span
                                >
                              </div>
                              <div class="grid gap-6 | lg:grid-cols-2">
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
