                            </button>
                          </div>
                        </div>

                        <!-- ── TAB 3: Pengalaman Kerja ──────────────────── -->
                        <div
                          id="tab-pengalaman"
                          class="hidden [&.is-active]:block"
                          data-tab-content
                          aria-hidden="true"
                        >
                          <div class="grid gap-16">
                            <div class="grid gap-8">
                              <h5>Informasi Pengalaman</h5>
                              <div
                                class="relative flex flex-col gap-12"
                                data-experience
                                id="experience-container"
                              >
                                {
                                  experiences.length === 0 ? (
                                    <div class="text-sm text-dark-400">
                                      Belum ada data pengalaman kerja.
                                    </div>
                                  ) : (
                                    experiences.map((exp: any, i: number) => (
                                      <div
                                        class="relative grid gap-6"
                                        data-experience-item
                                        data-exp-id={exp.id}
                                      >
                                        <div class="flex items-center gap-4">
                                          <h5 class="text-xl text-balance tracking-normal">
                                            Pengalaman{" "}
                                            {String(i + 1).padStart(2, "0")}.
                                          </h5>
                                          <div class="grow h-px bg-dark-300" />
                                        </div>
                                        <div class="grid gap-6 | lg:grid-cols-2">
                                          <div class="col-span-full | lg:col-span-1">
                                            <div class="c-form-wrapper">
                                              <div class="c-form c-form-default">
                                                <label class="c-label">
                                                  Nama Perusahaan
                                                </label>
                                                <input
                                                  type="text"
                                                  class="c-input"
                                                  value={exp.company_name ?? ""}
                                                  data-exp-field="company_name"
                                                />
                                              </div>
                                            </div>
                                          </div>
                                          <div class="col-span-full | lg:col-span-1">
                                            <div class="c-form-wrapper">
                                              <div class="c-form c-form-default">
                                                <label class="c-label">
                                                  Jabatan
                                                </label>
                                                <input
                                                  type="text"
                                                  class="c-input"
                                                  value={exp.position ?? ""}
                                                  data-exp-field="position"
                                                />
                                              </div>
                                            </div>
                                          </div>
                                          <div class="col-span-full | lg:col-span-1">
                                            <div class="c-form-wrapper">
                                              <div class="c-form c-form-default">
                                                <label class="c-label">
                                                  Tanggal Mulai
                                                </label>
                                                <input
                                                  type="text"
                                                  class="c-input"
                                                  value={exp.start_date ?? ""}
                                                  id={`pengalaman-from-date-${i + 1}`}
                                                  data-exp-field="start_date"
                                                  readonly
                                                  placeholder="dd mmmm, yyyy"
                                                />
                                              </div>
                                            </div>
                                          </div>
                                          <div class="col-span-full | lg:col-span-1">
                                            <div class="c-form-wrapper">
                                              <div class="c-form c-form-default">
                                                <label class="c-label">
                                                  Tanggal Selesai
                                                </label>
                                                <input
                                                  type="text"
                                                  class="c-input"
                                                  value={exp.finish_date ?? ""}
                                                  id={`pengalaman-to-date-${i + 1}`}
                                                  data-exp-field="finish_date"
                                                  readonly
                                                  placeholder="dd mmmm, yyyy"
                                                />
                                              </div>
                                            </div>
                                          </div>
                                          <div
                                            id={`pengalaman-datepicker-${i + 1}`}
                                            class="hidden"
                                          >
                                            <div data-rangepicker />
                                          </div>
                                          <div class="col-span-full">
                                            <div class="c-form-wrapper">
                                              <div class="c-form c-form-default">
                                                <label class="c-label">
                                                  Keterangan
                                                </label>
                                                <textarea
                                                  class="c-input c-textarea"
                                                  data-exp-field="description"
                                                  set:text={
                                                    exp.description ?? ""
                                                  }
                                                />
                                              </div>
                                            </div>
                                          </div>
                                          <div class="col-span-full | lg:col-span-1">
                                            <div class="c-form-wrapper">
                                              <div class="c-form c-form-default">
                                                <label class="c-label">
                                                  Gaji /bulan
                                                </label>
                                                <input
                                                  type="text"
                                                  inputmode="numeric"
                                                  class="c-input"
                                                  value={
                                                    exp.salary
                                                      ? `Rp ${Number(exp.salary).toLocaleString("id-ID")}`
                                                      : ""
                                                  }
                                                  data-exp-field="salary"
                                                  data-salary-input
                                                />
                                              </div>
                                            </div>
                                          </div>
                                        </div>
                                      </div>
                                    ))
                                  )
                                }
                              </div>
                            </div>
                          </div>

                          <div class="flex mt-16 | not-lg:justify-center">
