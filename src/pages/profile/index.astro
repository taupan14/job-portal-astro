                                      >
                                      <input
                                        type="text"
                                        name="nonformal_study"
                                        id="input-bidang-pelajaran"
                                        class="c-input"
                                        placeholder="Masukan bidang pelajaran"
                                        value={nonformalEdu?.study_name ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="input-lembaga-pendidikan"
                                        class="c-label"
                                        >Nama Lembaga Pendidikan</label
                                      >
                                      <input
                                        type="text"
                                        name="nonformal_school"
