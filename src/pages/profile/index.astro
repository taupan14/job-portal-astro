                          data-tab-content
                          aria-hidden="true"
                        >
                          <div class="grid gap-16">
                            <!-- Pendidikan Formal -->
                            <div class="grid gap-8">
                              <h5>Informasi Formal</h5>
                              <div class="grid gap-6 | lg:grid-cols-2">
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="select-last-education"
                                        class="c-label"
                                        >Pendidikan Terakhir</label
                                      >
                                      <select
                                        name="last_education"
                                        id="select-last-education"
                                        class="c-input c-select"
                                        data-selected-education={formalEdu?.last_education
                                          ? String(formalEdu.last_education)
                                          : ""}
                                      >
                                        <option
                                          value=""
                                          disabled
                                          selected={!formalEdu?.last_education}
                                          >Pilih pendidikan terakhir *</option
                                        >
                                        {
                                          (educations ?? []).map((e) => (
                                            <option
                                              value={String(e.id)}
                                              selected={
                                                formalEdu?.last_education ===
                                                e.id
                                              }
                                            >
                                              {e.name}
                                            </option>
                                          ))
                                        }
                                      </select>
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-sekolah" class="c-label"
                                        >Sekolah / Universitas</label
                                      >
                                      <input
                                        type="text"
                                        name="school_name"
                                        id="input-sekolah"
                                        class="c-input"
                                        placeholder="Masukan nama sekolah / universitas *"
                                        value={formalEdu?.school_name ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
