                            <!-- Form Informasi Pribadi -->
                            <div class="grid gap-8">
                              <h5>Informasi Pribadi</h5>
                              <div class="grid gap-6 | lg:grid-cols-2">
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-name" class="c-label"
                                        >Nama Pribadi</label
                                      >
                                      <input
                                        type="text"
                                        name="name"
                                        id="input-name"
                                        class="c-input"
                                        placeholder="Masukan nama lengkap *"
                                        value={profileData?.name ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="input-birthdate"
                                        class="c-label">Tanggal Lahir</label
                                      >
                                      <input
                                        type="text"
                                        name="birthdate"
                                        id="input-birthdate"
                                        class="c-input"
                                        placeholder="Pilih tanggal *"
                                        data-datepicker
                                        data-value={profileData?.date_of_birth ??
                                          ""}
                                        readonly
                                        value={formattedDob}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="select-gender" class="c-label"
                                        >Jenis Kelamin</label
                                      >
                                      <select
                                        name="gender"
                                        id="select-gender"
                                        class="c-input c-select"
                                        data-selected-gender={profileData?.gender ??
                                          ""}
                                      >
                                        <option
                                          value=""
                                          disabled
                                          selected={!profileData?.gender}
                                          >Pilih jenis kelamin *</option
                                        >
                                        <option
                                          value="Laki-laki"
                                          selected={profileData?.gender ===
                                            "Laki-laki"}>Laki-laki</option
                                        >
                                        <option
                                          value="Perempuan"
                                          selected={profileData?.gender ===
                                            "Perempuan"}>Perempuan</option
                                        >
                                      </select>
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="input-place-of-birth"
                                        class="c-label">Tempat Lahir</label
                                      >
                                      <input
                                        type="text"
                                        name="place_of_birth"
                                        id="input-place-of-birth"
                                        class="c-input"
                                        placeholder="Masukan tempat lahir *"
                                        value={profileData?.place_of_birth ??
                                          ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-nik" class="c-label"
                                        >NIK</label
                                      >
                                      <input
                                        type="text"
                                        inputmode="numeric"
                                        name="nik"
                                        id="input-nik"
                                        class="c-input"
                                        placeholder="Masukan NIK *"
                                        value={profileData?.ktp_number ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-email" class="c-label"
                                        >Email</label
                                      >
                                      <input
                                        type="email"
                                        name="email"
                                        id="input-email"
                                        class="c-input"
                                        placeholder="Masukan email *"
                                        value={profileData?.email ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-nohp" class="c-label"
                                        >Nomor HP</label
                                      >
                                      <input
                                        type="text"
                                        inputmode="numeric"
                                        name="phone_number"
                                        id="input-nohp"
                                        class="c-input"
                                        placeholder="Masukan nomor HP *"
                                        value={profileData?.phone_number ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>

                            <!-- Form Alamat -->
                            <div class="grid gap-8">
                              <h5>Informasi Alamat</h5>
                              <div class="grid gap-6 | lg:grid-cols-2">
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="select-province"
                                        class="c-label">Provinsi</label
                                      >
                                      <!-- 
                                        Simpan nama regency/district/village sebagai data-* 
                                        agar bisa di-restore client-side saat cascade populate
                                      -->
                                      <select
                                        name="province"
                                        id="select-province"
                                        class="c-input c-select"
                                        data-selected-province={profileData?.province ??
                                          ""}
                                        data-selected-regency={profileData?.regency ??
                                          ""}
                                        data-selected-district={profileData?.district ??
                                          ""}
                                        data-selected-village={profileData?.village ??
                                          ""}
                                      >
                                        <option
                                          value=""
                                          disabled
                                          selected={!provMatch}
                                          >Pilih provinsi *</option
                                        >
                                        {
                                          (provinces ?? []).map((p) => (
                                            <option
                                              value={p.id}
                                              selected={
                                                String(p.id) ===
                                                String(provMatch?.id)
                                              }
                                            >
                                              {p.name}
                                            </option>
                                          ))
                                        }
                                      </select>
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="select-cityreg"
                                        class="c-label">Kota / Kabupaten</label
                                      >
                                      <select
                                        name="regency"
                                        id="select-cityreg"
                                        class="c-input c-select"
                                      >
                                        <option value="" selected
                                          >Pilih kota/kabupaten *</option
                                        >
                                      </select>
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="select-subdistrict"
                                        class="c-label">Kecamatan</label
                                      >
                                      <select
                                        name="district"
                                        id="select-subdistrict"
                                        class="c-input c-select"
                                      >
                                        <option value="" selected
                                          >Pilih kecamatan *</option
                                        >
                                      </select>
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="select-ward" class="c-label"
                                        >Kelurahan</label
                                      >
                                      <select
                                        name="village"
                                        id="select-ward"
                                        class="c-input c-select"
                                      >
                                        <option value="" selected
                                          >Pilih kelurahan *</option
                                        >
                                      </select>
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full | lg:col-span-1">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label
                                        for="input-postalcode"
                                        class="c-label">Kode Pos</label
                                      >
                                      <input
                                        type="text"
                                        inputmode="numeric"
                                        name="poscode"
                                        id="input-postalcode"
                                        class="c-input"
                                        placeholder="Masukan kode pos *"
                                        value={profileData?.poscode ?? ""}
                                      />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-span-full">
                                  <div class="c-form-wrapper">
                                    <div class="c-form c-form-default">
                                      <label for="input-address" class="c-label"
                                        >Alamat Lengkap</label
                                      >
                                      <textarea
                                        name="address"
                                        id="input-address"
                                        class="c-input c-textarea"
                                        placeholder="Masukan alamat lengkap *"
                                        >{profileData?.address ?? ""}</textarea
                                      >
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div class="flex mt-16 | not-lg:justify-center">
                            <button
                              type="button"
                              class="inline-flex items-center gap-4 shrink-0"
