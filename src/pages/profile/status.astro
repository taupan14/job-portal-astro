                                    <svg class="icon icon-stroke size-4" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </span>
                                )}
                              </div>
                            </div>
                          )}
                        </div>
                      )}

                      <div class="absolute inset-y-0 left-0 w-dvw bg-dark-50 rounded-l-lg -z-1 | not-lg:hidden"></div>
