  <script>
    const initStatusPage = () => {
      const container = document.querySelector('[data-barba-namespace="profile-status"]');
      if (!container) return;

      // ── Row expand/collapse ───────────────────────────────────────────────
      container.querySelectorAll("[data-expand-trigger]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const id = (trigger as HTMLElement).dataset.applyId;
          const content = container.querySelector(`[data-expand-content][data-apply-id="${id}"]`);
          if (!content) return;

          const isExpanded = trigger.getAttribute("aria-expanded") === "true";

          if (isExpanded) {
            content.classList.add("hidden");
            trigger.setAttribute("aria-expanded", "false");
            trigger.classList.remove("is-expanded");
          } else {
            content.classList.remove("hidden");
            trigger.setAttribute("aria-expanded", "true");
            trigger.classList.add("is-expanded");
          }
        });
      });
    };

    // Barba.js: jalankan saat masuk halaman
    if (typeof window !== "undefined") {
      document.addEventListener("DOMContentLoaded", initStatusPage);
      window.addEventListener("barba:after", initStatusPage);
    }
  </script>

  <script type="module" src="/src/main.js"></script>
