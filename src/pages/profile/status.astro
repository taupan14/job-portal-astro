                                                    <div class="absolute left-0 top-1.5 size-2.5 rounded-full bg-primary-600 shrink-0 z-10"></div>
                                                    {i < app.logs.length - 1 && (
                                                      <div class="absolute left-[4.5px] top-4 bottom-[-1.5rem] w-px bg-dark-200"></div>
                                                    )}
                                                    <div class="flex flex-col gap-1 min-w-0">
                                                      <div class="flex items-center gap-3 flex-wrap">
                                                        <span class="text-xs text-dark-400 whitespace-nowrap">{formatDateTime(log.created_at)}</span>
                                                        {log.created_by && (
                                                          <span class="text-xs font-semibold text-dark-600">{log.created_by}</span>
                                                        )}
                                                      </div>
                                                      <p class="text-sm text-dark-950">{log.comment}</p>
                                                      {log.document && (
                                                        <a
                                                          href={`${import.meta.env.PUBLIC_API_URL}/pubs/uploads/documents/${log.document}`}
                                                          target="_blank"
                                                          rel="noopener noreferrer"
                                                          class="inline-flex items-center gap-2 text-xs text-primary-600 hover:underline mt-1"
                                                        >
                                                          <svg class="icon icon-stroke size-3.5" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M9 17H15M9 13H15M9 9H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                            <path d="M3 10C3 6.22876 3 4.34315 4.17157 3.17157C5.34315 2 7.22876 2 11 2H13C16.7712 2 18.6569 2 19.8284 3.17157C21 4.34315 21 6.22876 21 10V14C21 17.7712 21 19.6569 19.8284 20.8284C18.6569 22 16.7712 22 13 22H11C7.22876 22 5.34315 22 4.17157 20.8284C3 19.6569 3 17.7712 3 14V10Z" stroke="currentColor" stroke-width="1.5"/>
                                                          </svg>
                                                          Lihat File
                                                        </a>
                                                      )}
                                                    </div>
                                                  </div>
                                                ))}
                                              </div>
                                            </div>
                                          )}
                                        </div>
                                      </td>
                                    </tr>
                                  </>
                                ))}
                              </tbody>
                            </table>
                          </div>

                          <!-- ── Pagination ──────────────────────────────── -->
                          {totalPages > 1 && (
                            <div class="flex items-center justify-between gap-4 pt-4 border-t border-dark-200">
                              <p class="text-xs text-dark-400">
                                Halaman {currentPage} dari {totalPages}
                              </p>
                              <div class="flex items-center gap-2">
                                {currentPage > 1 ? (
                                  <a
                                    href={`?page=${currentPage - 1}`}
                                    class="btn btn-icon btn-xs btn-dark"
                                    aria-label="Halaman sebelumnya"
                                  >
                                    <svg class="icon icon-stroke size-4" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </a>
                                ) : (
                                  <span class="btn btn-icon btn-xs btn-dark opacity-30 pointer-events-none" aria-disabled="true">
                                    <svg class="icon icon-stroke size-4" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </span>
                                )}

                                <div class="flex items-center gap-1">
                                  {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
                                    <a
                                      href={`?page=${p}`}
                                      class:list={[
                                        "inline-flex items-center justify-center size-8 rounded-lg text-xs font-semibold transition-colors duration-200",
                                        p === currentPage
                                          ? "bg-primary-600 text-white"
                                          : "hover:bg-dark-100 text-dark-600",
                                      ]}
                                    >
                                      {p}
                                    </a>
                                  ))}
                                </div>

                                {currentPage < totalPages ? (
                                  <a
                                    href={`?page=${currentPage + 1}`}
                                    class="btn btn-icon btn-xs btn-dark"
                                    aria-label="Halaman berikutnya"
                                  >
                                    <svg class="icon icon-stroke size-4" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </a>
