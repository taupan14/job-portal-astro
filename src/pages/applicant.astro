<!-- ── Page Script ──────────────────────────────────────────────────────── -->
<script>
  import {
    initFormApplicant,
    initTabs,
    initExperienceRows,
    initCurrencyInputs,
  } from "../scripts/form/formApplicant";
  import TomSelect from "tom-select";

  const BASE_URL = `${import.meta.env.PUBLIC_API_URL}/api/wai`;
  const API_URL = import.meta.env.PUBLIC_API_URL;

  // ── Load Education List ──────────────────────────────────────────────────
  const selectEdu = document.getElementById(
    "select-last-education",
  ) as HTMLSelectElement | null;
  if (selectEdu) {
    try {
      const res = await fetch(`${API_URL}/api/educations`);
      const data: { id: number; name: string }[] = await res.json();
      data.forEach((edu) => {
        const opt = document.createElement("option");
        opt.value = String(edu.id);
        opt.textContent = edu.name;
        selectEdu.appendChild(opt);
      });
    } catch (e) {
      console.error("Gagal memuat data pendidikan:", e);
    }
  }

  // ── Regional Cascade ─────────────────────────────────────────────────────
  async function populateSelect(
    url: string,
    select: HTMLSelectElement,
    placeholder: string,
  ): Promise<void> {
    const ts = (select as any).tomselect as TomSelect | undefined;

    if (ts) {
      ts.clear(true);
      ts.clearOptions();
      ts.disable();
      ts.addOption({ value: "", text: placeholder });
      ts.setValue("", true);
    } else {
      select.innerHTML = `<option value="" disabled selected>${placeholder}</option>`;
      select.disabled = true;
    }

    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error(`HTTP error: ${res.status}`);
      const data: { id: string; name: string }[] = await res.json();

      if (ts) {
        ts.clearOptions();
        ts.addOption({ value: "", text: placeholder });
        data.forEach((item) =>
          ts.addOption({ value: item.id, text: item.name }),
        );
        ts.refreshOptions(false);
        ts.enable();
        ts.setValue("", true);
      } else {
        data.forEach((item) => {
          const opt = document.createElement("option");
          opt.value = item.id;
          opt.textContent = item.name;
          select.appendChild(opt);
        });
        select.disabled = false;
      }
    } catch (err) {
      console.error(`Gagal memuat data dari ${url}:`, err);
    }
  }

  function resetSelect(select: HTMLSelectElement, placeholder: string): void {
    const ts = (select as any).tomselect as TomSelect | undefined;
    if (ts) {
      ts.clear(true);
      ts.clearOptions();
      ts.addOption({ value: "", text: placeholder });
      ts.setValue("", true);
      ts.disable();
    } else {
      select.innerHTML = `<option value="" disabled selected>${placeholder}</option>`;
      select.disabled = true;
    }
  }

  const selProvince = document.getElementById(
    "select-province",
  ) as HTMLSelectElement | null;
  const selCityreg = document.getElementById(
    "select-cityreg",
  ) as HTMLSelectElement | null;
  const selSubdistrict = document.getElementById(
    "select-subdistrict",
  ) as HTMLSelectElement | null;
  const selWard = document.getElementById(
    "select-ward",
  ) as HTMLSelectElement | null;

  if (selProvince && selCityreg && selSubdistrict && selWard) {
    selProvince.addEventListener("change", () => {
      const id = selProvince.value;
      resetSelect(selCityreg, "Pilih kota/kabupaten *");
      resetSelect(selSubdistrict, "Pilih kecamatan *");
      resetSelect(selWard, "Pilih kelurahan *");
      if (id)
        populateSelect(
          `${BASE_URL}/regencies/${id}`,
          selCityreg,
          "Pilih kota/kabupaten *",
        );
    });

    selCityreg.addEventListener("change", () => {
      const id = selCityreg.value;
      resetSelect(selSubdistrict, "Pilih kecamatan *");
      resetSelect(selWard, "Pilih kelurahan *");
      if (id)
        populateSelect(
          `${BASE_URL}/districts/${id}`,
          selSubdistrict,
          "Pilih kecamatan *",
        );
    });

    selSubdistrict.addEventListener("change", () => {
      const id = selSubdistrict.value;
      resetSelect(selWard, "Pilih kelurahan *");
      if (id)
        populateSelect(
          `${BASE_URL}/villages/${id}`,
          selWard,
          "Pilih kelurahan *",
        );
    });
  }

  // ── Init semua fungsi ────────────────────────────────────────────────────
  initTabs();
  initExperienceRows();
  initCurrencyInputs();
  initFormApplicant();
</script>
