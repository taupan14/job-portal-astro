---
import BaseLayout from "../layouts/BaseLayout.astro";
import { apiGet } from "../lib/api";

const cookieHeader = Astro.request.headers.get("cookie") ?? "";

const provinces =
  (await apiGet<{ id: string; name: string }[]>(
    "/api/wai/provinces",
    cookieHeader,
  )) ?? [];
---

<BaseLayout title="Daftar Pelamar">
  <div id="app">
    <main id="section-main" data-barba="wrapper">
      <div
        data-hero-scheme="light"
        data-barba="container"
        data-barba-namespace="auth-signup-applicant"
      >
        <section id="page-content" class="relative pt-(--space-header)">
          <div class="py-16 | lg:pb-24">
            <div class="max-container" data-tabs>
              <!-- ── Tab Navigation ──────────────────────────────────────── -->
              <div
                class="relative isolate flex overflow-auto mb-16"
                data-tab-scroll
              >
                <ul
                  class="relative isolate flex items-center flex-nowrap whitespace-nowrap gap-8 | lg:gap-16"
                  data-tab-slider
                >
                  <li class="shrink-0">
                    <button
                      type="button"
                      class="inline-flex pb-4 transition-colors duration-800 ease-custom text-sm font-bold uppercase tracking-wide [&.is-active]:text-dark-950 is-active"
                      data-tab-nav
                      data-tab-target="tab-informasi">Informasi Pribadi</button
                    >
                  </li>
                  <li class="shrink-0">
                    <button
                      type="button"
                      class="inline-flex pb-4 transition-colors duration-800 ease-custom text-sm font-bold uppercase tracking-wide [&.is-active]:text-dark-950"
                      data-tab-nav
                      data-tab-target="tab-pendidikan">Pendidikan</button
                    >
                  </li>
                  <li class="shrink-0">
                    <button
                      type="button"
                      class="inline-flex pb-4 transition-colors duration-800 ease-custom text-sm font-bold uppercase tracking-wide [&.is-active]:text-dark-950"
                      data-tab-nav
                      data-tab-target="tab-pengalaman">Pengalaman Kerja</button
                    >
                  </li>
                </ul>
                <div class="absolute inset-x-0 bottom-0 h-px bg-dark-200 -z-2">
                </div>
              </div>

              <!-- ── Tab Contents ────────────────────────────────────────── -->
              <div class="relative" data-tabs-content>
                <!-- ── TAB 1: Informasi Pribadi ────────────────────────── -->
                <div
                  id="tab-informasi"
                  class="hidden [&.is-active]:block is-active"
                  data-tab-content
                  aria-hidden="false"
                >
                  <!-- Foto & Data Diri -->
                  <div class="grid gap-16 mb-16 | lg:grid-cols-[18rem_1fr]">
                    <!-- Foto -->
                    <div class="flex flex-col gap-4 | lg:gap-6">
                      <div
                        class="relative aspect-square rounded-lg overflow-clip flex items-center justify-center bg-dark-100 shrink-0"
                        data-photo
                      >
                        <svg
                          class="icon icon-fill size-14 text-primary-600"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <path
                            opacity="0.4"
                            fill-rule="evenodd"
                            clip-rule="evenodd"
                            d="M20.1129 7.78312C19.6979 7.36808 19.0964 7.11438 17.8757 6.9943L18.0715 5.00391C19.4675 5.14123 20.6275 5.46925 21.5272 6.36891C22.3335 7.1752 22.6805 8.19058 22.8428 9.39768C22.9992 10.5606 22.9991 12.0394 22.9991 13.8748V14.0212C22.9991 15.8567 22.9992 17.3355 22.8428 18.4984C22.6805 19.7055 22.3335 20.7209 21.5272 21.5272C20.7209 22.3335 19.7055 22.6805 18.4984 22.8428C17.3355 22.9992 15.8567 22.9991 14.0212 22.9991H13.8748C12.0394 22.9991 10.5606 22.9992 9.39768 22.8428C8.19058 22.6805 7.1752 22.3335 6.36891 21.5272C5.46925 20.6275 5.14123 19.4675 5.00391 18.0715L6.9943 17.8757C7.11438 19.0964 7.36808 19.6979 7.78312 20.1129C8.15588 20.4857 8.67885 20.7282 9.66417 20.8606C10.6783 20.997 12.0221 20.9991 13.948 20.9991C15.874 20.9991 17.2178 20.997 18.2319 20.8606C19.2172 20.7282 19.7402 20.4857 20.1129 20.1129C20.4857 19.7402 20.7282 19.2172 20.8606 18.2319C20.997 17.2178 20.9991 15.874 20.9991 13.948C20.9991 12.0221 20.997 10.6783 20.8606 9.66417C20.7282 8.67885 20.4857 8.15588 20.1129 7.78312Z"
                            fill="#141B34"></path>
                          <path
                            opacity="0.4"
                            d="M11.6363 12.4162C9.4301 10.9618 6.68031 10.2023 3.87635 10.2523C3.2166 10.2512 2.55784 10.2921 1.90597 10.3744C1.53026 10.4219 1.24888 10.742 1.25 11.1207C1.25458 12.6661 1.28026 13.8928 1.45316 14.8725C1.63123 15.8815 1.97481 16.6895 2.64946 17.3603C3.40134 18.1079 4.35431 18.4395 5.53219 18.5969C6.67735 18.75 8.14081 18.75 9.98955 18.75L10.1393 18.75C12.2827 18.7501 13.9178 18.7501 15.1501 18.4985C15.3602 18.4556 15.5419 18.3248 15.6492 18.1391C15.7566 17.9535 15.7794 17.7308 15.7118 17.5272C15.0373 15.4965 13.6026 13.7125 11.6363 12.4162Z"
                            fill="#141B34"></path>
                          <path
                            fill-rule="evenodd"
                            clip-rule="evenodd"
                            d="M9.92684 1H10.0732C11.8966 0.999973 13.3664 0.999951 14.5223 1.15537C15.7225 1.31672 16.733 1.66191 17.5355 2.46447C18.3381 3.26702 18.6833 4.27752 18.8446 5.47767C19.0001 6.63362 19 8.10336 19 9.9268V10.0732C19 11.8966 19.0001 13.3664 18.8446 14.5223C18.6833 15.7225 18.3381 16.733 17.5355 17.5355C16.733 18.3381 15.7225 18.6833 14.5223 18.8446C13.3664 19.0001 11.8966 19 10.0732 19H9.9268C8.10336 19 6.63362 19.0001 5.47767 18.8446C4.27752 18.6833 3.26702 18.3381 2.46447 17.5355C1.66191 16.733 1.31672 15.7225 1.15537 14.5223C0.999951 13.3664 0.999973 11.8966 1 10.0732V9.92684C0.999973 8.10338 0.999951 6.63362 1.15537 5.47767C1.31672 4.27752 1.66191 3.26702 2.46447 2.46447C3.26702 1.66191 4.27752 1.31672 5.47767 1.15537C6.63362 0.999951 8.10338 0.999973 9.92684 1ZM5.74416 3.13753C4.76579 3.26907 4.2477 3.50966 3.87868 3.87868C3.50966 4.2477 3.26907 4.76579 3.13753 5.74416C3.00213 6.7513 3 8.08611 3 10C3 11.9139 3.00213 13.2487 3.13753 14.2558C3.26907 15.2342 3.50966 15.7523 3.87868 16.1213C4.2477 16.4903 4.76579 16.7309 5.74416 16.8625C6.7513 16.9979 8.08611 17 10 17C11.9139 17 13.2487 16.9979 14.2558 16.8625C15.2342 16.7309 15.7523 16.4903 16.1213 16.1213C16.4903 15.7523 16.7309 15.2342 16.8625 14.2558C16.9979 13.2487 17 11.9139 17 10C17 8.08611 16.9979 6.7513 16.8625 5.74416C16.7309 4.76579 16.4903 4.2477 16.1213 3.87868C15.7523 3.50966 15.2342 3.26907 14.2558 3.13753C13.2487 3.00213 11.9139 3 10 3C8.08611 3 6.7513 3.00213 5.74416 3.13753Z"
                            fill="#141B34"></path>
                          <path
                            fill-rule="evenodd"
                            clip-rule="evenodd"
                            d="M12 6.75C12 6.05964 12.5571 5.5 13.2444 5.5C13.9268 5.5 14.5 6.05988 14.5 6.75C14.5 7.44012 13.9268 8 13.2444 8C12.5571 8 12 7.44036 12 6.75Z"
                            fill="#141B34"></path>
                        </svg>
                        <label
                          for="input-photo-profile"
                          class="absolute isolate inset-0 cursor-pointer flex justify-end p-2 group"
                        >
                          <input
                            type="file"
                            name="photo-profile"
                            id="input-photo-profile"
                            accept="image/png, image/gif, image/jpeg, image/svg, image/gif"
                            hidden
                            data-input-photo
                          />
                          <div
                            class="btn btn-icon btn-dark opacity-0 group-hover:opacity-100"
                          >
                            <svg
                              class="icon icon-stroke"
                              width="24"
                              height="24"
                              viewBox="0 0 24 24"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M5 21C9.20998 16.2487 13.9412 9.9475 21 14.6734"
                                stroke="#141B34"
                                stroke-width="1.5"></path>
                              <path
                                d="M14 3.00231C13.5299 3 12.0307 3 11.5 3C7.02166 3 4.78249 3 3.39124 4.39124C2 5.78249 2 8.02166 2 12.5C2 16.9783 2 19.2175 3.39124 20.6088C4.78249 22 7.02166 22 11.5 22C15.9783 22 18.2175 22 19.6088 20.6088C20.9472 19.2703 20.998 17.147 20.9999 13"
                                stroke="#141B34"
                                stroke-width="1.5"
                                stroke-linecap="round"></path>
                              <path
                                d="M17 7.5C17.4915 8.0057 18.7998 10 19.5 10M22 7.5C21.5085 8.0057 20.2002 10 19.5 10M19.5 10V2"
                                stroke="#141B34"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                            </svg>
                          </div>
                        </label>
                      </div>
                      <div class="w-full text-xs font-medium">
                        Besar file: maksimum 10.000.000 bytes (10 MB). Ekstensi
                        yang diperbolehkan: .JPG .JPEG .PNG
                      </div>
                    </div>

                    <!-- Data Pribadi -->
                    <div class="grid gap-8">
                      <h5>Informasi Pribadi</h5>
                      <div class="grid gap-6">
                        <div class="c-form-wrapper">
                          <div class="c-form c-form-default">
                            <label for="input-name" class="c-label"
                              >Nama Lengkap</label
                            >
                            <input
                              type="text"
                              name="name"
                              id="input-name"
                              class="c-input"
                              placeholder="Masukan nama lengkap *"
                            />
                          </div>
                        </div>
                        <div class="c-form-wrapper">
                          <div class="c-form c-form-default">
                            <label for="input-place-of-birth" class="c-label"
                              >Tempat Lahir</label
                            >
                            <input
                              type="text"
                              name="place-of-birth"
                              id="input-place-of-birth"
                              class="c-input"
                              placeholder="Masukan tempat lahir *"
                            />
                          </div>
                        </div>
                        <div class="c-form-wrapper">
                          <div class="c-form c-form-default">
                            <label for="input-birthdate" class="c-label"
                              >Tanggal Lahir</label
                            >
                            <input
                              type="text"
                              name="birthdate"
                              id="input-birthdate"
                              class="c-input"
                              placeholder="Pilih tanggal *"
                            />
                          </div>
                        </div>
                        <div class="c-form-wrapper">
                          <div class="c-form c-form-default">
                            <label for="select-gender" class="c-label"
                              >Jenis Kelamin</label
                            >
                            <select
                              name="gender"
                              id="select-gender"
                              class="c-input c-select"
                            >
                              <option value="" disabled selected
                                >Pilih jenis kelamin *</option
                              >
                              <option value="Laki-laki">Laki-laki</option>
                              <option value="Perempuan">Perempuan</option>
                            </select>
                          </div>
                        </div>
                        <div class="c-form-wrapper">
                          <div class="c-form c-form-default">
                            <label for="input-nik" class="c-label"
                              >Nomor KTP</label
                            >
                            <input
                              type="number"
                              inputmode="numeric"
                              name="nik"
                              id="input-nik"
                              class="c-input"
                              placeholder="Masukan NIK *"
                            />
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Kontak & Alamat -->
                  <div class="grid gap-16">
                    <div class="grid gap-8">
                      <h5>Informasi Kontak</h5>
                      <div class="grid gap-6 | lg:grid-cols-2">
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="input-email" class="c-label"
                                >Email</label
                              >
                              <input
                                type="email"
                                name="email"
                                id="input-email"
                                class="c-input"
                                placeholder="Masukan email *"
                              />
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="input-nohp" class="c-label"
                                >Nomor HP</label
                              >
                              <input
                                type="number"
                                inputmode="numeric"
                                name="nohp"
                                id="input-nohp"
                                class="c-input"
                                placeholder="Masukan nomor HP *"
                              />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="grid gap-8">
                      <h5>Informasi Alamat</h5>
                      <div class="grid gap-6 | lg:grid-cols-2">
                        <div class="col-span-full">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="input-address" class="c-label"
                                >Alamat Lengkap</label
                              >
                              <textarea
                                name="address"
                                id="input-address"
                                class="c-input c-textarea"
                                placeholder="Masukan alamat lengkap *"
                              ></textarea>
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="select-province" class="c-label"
                                >Provinsi</label
                              >
                              <select
                                name="province"
                                id="select-province"
                                class="c-input c-select"
                              >
                                <option value="" disabled selected
                                  >Pilih provinsi *</option
                                >
                                {
                                  provinces.map((p) => (
                                    <option value={p.id}>{p.name}</option>
                                  ))
                                }
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="select-cityreg" class="c-label"
                                >Kota/Kab.</label
                              >
                              <select
                                name="cityreg"
                                id="select-cityreg"
                                class="c-input c-select"
                                disabled
                              >
                                <option value="" disabled selected
                                  >Pilih kota/kabupaten *</option
                                >
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="select-subdistrict" class="c-label"
                                >Kecamatan</label
                              >
                              <select
                                name="subdistrict"
                                id="select-subdistrict"
                                class="c-input c-select"
                                disabled
                              >
                                <option value="" disabled selected
                                  >Pilih kecamatan *</option
                                >
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="select-ward" class="c-label"
                                >Kelurahan</label
                              >
                              <select
                                name="ward"
                                id="select-ward"
                                class="c-input c-select"
                                disabled
                              >
                                <option value="" disabled selected
                                  >Pilih kelurahan *</option
                                >
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="input-postalcode" class="c-label"
                                >Kodepos</label
                              >
                              <input
                                type="number"
                                inputmode="numeric"
                                name="postalcode"
                                id="input-postalcode"
                                class="c-input"
                                placeholder="Masukan kodepos *"
                              />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- ── TAB 2: Pendidikan ───────────────────────────────── -->
                <div
                  id="tab-pendidikan"
                  class="hidden [&.is-active]:block"
                  data-tab-content
                  aria-hidden="true"
                >
                  <div class="grid gap-16">
                    <!-- Pendidikan Formal -->
                    <div class="grid gap-8">
                      <h5>Pendidikan Formal</h5>
                      <div class="grid gap-6 | lg:grid-cols-2">
                        <!-- Select Pendidikan Terakhir dari backend -->
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="select-last-education" class="c-label"
                                >Pendidikan Terakhir</label
                              >
                              <select
                                name="last-education"
                                id="select-last-education"
                                class="c-input c-select"
                              >
                                <option value="" disabled selected
                                  >Pilih pendidikan terakhir *</option
                                >
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="input-sekolah" class="c-label"
                                >Sekolah / Universitas</label
                              >
                              <input
                                type="text"
                                name="sekolah"
                                id="input-sekolah"
                                class="c-input"
                                placeholder="Masukan nama sekolah / universitas *"
                              />
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="formal-from-date" class="c-label"
                                >Tanggal Mulai</label
                              >
                              <input
                                type="text"
                                class="c-input"
                                name="formal-from-date"
                                id="formal-from-date"
                                placeholder="dd mmmm, yyyy"
                                readonly
                              />
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="formal-to-date" class="c-label"
                                >Tanggal Selesai</label
                              >
                              <input
                                type="text"
                                class="c-input"
                                name="formal-to-date"
                                id="formal-to-date"
                                placeholder="dd mmmm, yyyy"
                                readonly
                              />
                            </div>
                          </div>
                        </div>
                        <div id="formal-datepicker" class="hidden">
                          <div data-rangepicker></div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="input-jurusan" class="c-label"
                                >Jurusan / Program Studi</label
                              >
                              <input
                                type="text"
                                name="jurusan"
                                id="input-jurusan"
                                class="c-input"
                                placeholder="Masukan jurusan *"
                              />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Pendidikan Non-Formal (Opsional) -->
                    <div class="grid gap-8">
                      <div class="flex items-center gap-4">
                        <h5>Pendidikan Non-Formal</h5>
                        <span
                          class="text-xs font-medium text-dark-400 bg-dark-100 px-2 py-1 rounded-full"
                          >Opsional</span
                        >
                      </div>
                      <div class="grid gap-6 | lg:grid-cols-2">
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label
                                for="input-bidang-pelajaran"
                                class="c-label">Bidang Pelajaran</label
                              >
                              <input
                                type="text"
                                name="bidang-pelajaran"
                                id="input-bidang-pelajaran"
                                class="c-input"
                                placeholder="Masukan bidang pelajaran"
                              />
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label
                                for="input-lembaga-pendidikan"
                                class="c-label">Nama Lembaga Pendidikan</label
                              >
                              <input
                                type="text"
                                name="lembaga-pendidikan"
                                id="input-lembaga-pendidikan"
                                class="c-input"
                                placeholder="Masukan nama lembaga"
                              />
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="nonformal-from-date" class="c-label"
                                >Tanggal Mulai</label
                              >
                              <input
                                type="text"
                                class="c-input"
                                name="nonformal-from-date"
                                id="nonformal-from-date"
                                placeholder="dd mmmm, yyyy"
                                readonly
                              />
                            </div>
                          </div>
                        </div>
                        <div class="col-span-full | lg:col-span-1">
                          <div class="c-form-wrapper">
                            <div class="c-form c-form-default">
                              <label for="nonformal-to-date" class="c-label"
                                >Tanggal Selesai</label
                              >
                              <input
                                type="text"
                                class="c-input"
                                name="nonformal-to-date"
                                id="nonformal-to-date"
                                placeholder="dd mmmm, yyyy"
                                readonly
                              />
                            </div>
                          </div>
                        </div>
                        <div id="nonformal-datepicker" class="hidden">
                          <div data-rangepicker></div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- ── TAB 3: Pengalaman Kerja ─────────────────────────── -->
